/-- SU(9) has exactly 80 basis elements in E₈. -/
theorem su9_count : ((List.range 248).filter (fun n => isSU9 n)).length = 80 := by
  native_decide

/-- Every term in [B_i, B_j] for SU(9) elements is an SU(9) element. -/
def su9ClosedCheck (i j : Nat) : Bool :=
  (bkt i j).all fun (k, _) => isSU9 k

/-- SU(9) = A₈ is closed under the E₈ bracket.
    For all pairs of SU(9) basis elements, the bracket [B_i, B_j]
    contains only SU(9) basis elements.

    This verifies that SU(9) is a genuine Lie subalgebra of E₈,
    not just a subspace. Combined with the Jacobi identity for E₈
    (e8_sparse_jac_00..15.lean), this proves that the SU(9) generators
    inherit a Lie algebra structure from E₈. -/
theorem su9_subalgebra_e8 : ∀ (i j : Fin 248),
    isSU9 i.val = true → isSU9 j.val = true →
    (bkt i.val j.val).all (fun (k, _) => isSU9 k) = true := by
  native_decide

/-- The complement of SU(9) in E₈ has 168 = 84 + 84* dimensions. -/
theorem su9_complement_dim :
    ((List.range 248).filter (fun n => !isSU9 n)).length = 168 := by
  native_decide

/-- 80 + 168 = 248 (SU(9) + complement = E₈). -/
theorem su9_decomposition : 80 + 168 = 248 := by norm_num

