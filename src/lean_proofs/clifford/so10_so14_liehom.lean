/-! ## Part 2: Linearity Proofs -/

theorem so10_toSO14_add (a b : SO10) :
    so10_toSO14 (a + b) = so10_toSO14 a + so10_toSO14 b := by
  ext <;> simp [so10_toSO14, SO10.add, SO14.add, SO10.add_def, SO14.add_def] <;> ring

theorem so10_toSO14_smul (r : ℝ) (a : SO10) :
    so10_toSO14 (r • a) = r • so10_toSO14 a := by
  ext <;> simp [so10_toSO14, SO10.smul, SO14.smul, SO10.smul_def', SO14.smul_def'] <;> ring

/-! ## Part 3: Bracket Preservation (The Main Theorem) -/

set_option maxHeartbeats 128000000 in
/-- THE HOMOMORPHISM THEOREM: the embedding preserves the Lie bracket.
    so10_toSO14([X,Y]_{so10}) = [so10_toSO14(X), so10_toSO14(Y)]_{so14}

    This certifies that so(10) is a genuine Lie subalgebra of so(14),
    with the gauge-sector bracket preserved exactly.

    90 input variables (45 per argument) × 91 output goals × polynomial ring.
    Budget: 128M heartbeats. Many output components are trivially zero
    (mixed/gravity fields are zero on both sides). -/
theorem so10_toSO14_lie (x y : SO10) :
    so10_toSO14 ⁅x, y⁆ = ⁅so10_toSO14 x, so10_toSO14 y⁆ := by
  ext <;> simp [so10_toSO14, SO10.comm, SO14.comm, SO10.bracket_def', SO14.bracket_def'] <;> ring

/-! ## Part 4: The Certified LieHom -/

/-- The certified Lie algebra homomorphism SO10 →ₗ⁅ℝ⁆ SO14.
    This is the gauge-sector embedding for the unified theory:
    SU5C →ₗ⁅ℝ⁆ SO10 →ₗ⁅ℝ⁆ SO14 (composable morphism chain).

    Combined with the existing su5c_embed : SU5C →ₗ⁅ℝ⁆ SO10,
    this gives a two-arrow certified chain from su(5) to so(14). -/
def so10_embed : SO10 →ₗ⁅ℝ⁆ SO14 :=
  { toLinearMap := {
      toFun := so10_toSO14
      map_add' := so10_toSO14_add
      map_smul' := so10_toSO14_smul
    }
    map_lie' := fun {x} {y} => so10_toSO14_lie x y }

