import Mathlib.Data.Complex.Basic
import Mathlib.Analysis.Complex.Exponential
import Mathlib.Analysis.Complex.Trigonometric
import Mathlib.Analysis.SpecialFunctions.Trigonometric.Basic
import Mathlib.Algebra.Ring.Basic
import Mathlib.Tactic

-- ============================================================================
-- Local helper: exp(z)^n = exp(n*z), proved by induction + exp_add.
-- This avoids dependence on any specific mathlib API name.
-- ============================================================================

private lemma exp_nat_mul (z : ℂ) (n : ℕ) :
    Complex.exp z ^ n = Complex.exp (↑n * z) := by
  induction n with
  | zero => simp
  | succ n ih =>
    rw [pow_succ, ih, ← Complex.exp_add]
    push_cast
    ring

-- ============================================================================
-- Section 1: Core Definitions
-- ============================================================================

/-- The primitive Nth root of unity: omega_N = exp(2 * pi * I / N).
    This is the generator of the cyclic group of Nth roots of unity. -/
noncomputable def omega (N : ℕ) : ℂ :=
  Complex.exp (2 * Real.pi * Complex.I / N)

/-- The general Nth root of unity at position n: exp(2 * pi * I * n / N).
    For a given N, these are the N distinct Nth roots of unity as n ranges
    over {0, 1, ..., N-1}. -/
noncomputable def nthRootUnity (n N : ℕ) : ℂ :=
  Complex.exp (2 * Real.pi * Complex.I * n / N)

-- ============================================================================
-- Section 2: Fundamental Properties
-- ============================================================================

/-- The general root is a power of the primitive root: omega(N)^n = nthRootUnity(n, N).
    This is the key algebraic fact: all roots of unity are generated by the primitive root.
    Proof: exp(2*pi*I/N)^n = exp(2*pi*I*n/N) by the exponential law exp(a)^n = exp(n*a). -/
theorem omega_power_eq_nthRoot (n N : ℕ) (hN : (N : ℂ) ≠ 0) :
    omega N ^ n = nthRootUnity n N := by
  simp only [omega, nthRootUnity]
  rw [exp_nat_mul]
  congr 1
  field_simp

/-- The zeroth root of unity is always 1: exp(0) = 1. -/
theorem nthRootUnity_zero (N : ℕ) : nthRootUnity 0 N = 1 := by
  simp [nthRootUnity]

-- ============================================================================
-- Section 3: omega_N ^ N = 1 (The Central Theorem)
-- ============================================================================

/-- Key lemma: The exponent in omega(N)^N simplifies to 2*pi*I.
    When we compute exp(2*pi*I/N)^N, the exponent becomes N * (2*pi*I/N) = 2*pi*I. -/
theorem omega_exponent_simplifies (N : ℕ) (hN : (N : ℂ) ≠ 0) :
    (N : ℂ) * (2 * ↑Real.pi * Complex.I / (N : ℂ)) = 2 * ↑Real.pi * Complex.I := by
  field_simp

/-- Central theorem: omega(N)^N = 1.
    An Nth root of unity raised to the Nth power equals 1.

    Mathematical justification:
      omega(N)^N = exp(2*pi*I/N)^N = exp(N * 2*pi*I/N) = exp(2*pi*I) = 1

    The final step exp(2*pi*I) = 1 is Euler's identity in its periodicity form.
    This requires mathlib's Complex.exp_two_pi_mul_I or equivalent. -/
theorem omega_pow_N (N : ℕ) (hN : (N : ℂ) ≠ 0) :
    omega N ^ N = 1 := by
  simp only [omega]
  rw [exp_nat_mul]
  have h_exp : (N : ℂ) * (2 * ↑Real.pi * Complex.I / (N : ℂ)) =
    2 * ↑Real.pi * Complex.I := omega_exponent_simplifies N hN
  rw [h_exp]
  exact Complex.exp_two_pi_mul_I

/-- Corollary: nthRootUnity(N, N) = 1. Directly from the definition. -/
theorem nthRootUnity_self (N : ℕ) (hN : (N : ℂ) ≠ 0) :
    nthRootUnity N N = 1 := by
  rw [← omega_power_eq_nthRoot N N hN]
  exact omega_pow_N N hN

-- ============================================================================
-- Section 4: 3-Phase Specialization
-- ============================================================================
-- The 3-phase system is the workhorse of AC power distribution.
-- a = exp(2*pi*I/3) is the primitive cube root of unity.
-- Dollard's polyphase formula specializes to the standard 120-degree separation.

/-- The primitive cube root of unity. -/
noncomputable def alpha : ℂ := omega 3

/-- alpha is exp(2*pi*I/3). -/
theorem alpha_def : alpha = Complex.exp (2 * Real.pi * Complex.I / 3) := by
  simp [alpha, omega]

/-- a^3 = 1: The cube root of unity cubed equals 1.
    This is the 3-phase specialization of the central theorem. -/
theorem alpha_cubed : alpha ^ 3 = 1 := by
  have hN : (3 : ℂ) ≠ 0 := by norm_num
  exact omega_pow_N 3 hN

/-- The three cube roots of unity are {1, a, a^2}.
    These correspond to the three phases at 0, 120, and 240 degrees. -/
theorem three_phase_roots :
    nthRootUnity 0 3 = 1 ∧
    nthRootUnity 1 3 = alpha ∧
    nthRootUnity 2 3 = alpha ^ 2 := by
  refine ⟨nthRootUnity_zero 3, ?_, ?_⟩
  · -- nthRootUnity 1 3 = alpha
    have hN : (3 : ℂ) ≠ 0 := by norm_num
    rw [← omega_power_eq_nthRoot 1 3 hN]
    simp [alpha]
  · -- nthRootUnity 2 3 = alpha^2
    have hN : (3 : ℂ) ≠ 0 := by norm_num
    rw [← omega_power_eq_nthRoot 2 3 hN]
    simp [alpha]

/-- Sum of cube roots of unity: 1 + a + a^2 = 0.
    This is the balanced-phase property: the three phases sum to zero.
    This is a fundamental property used in Fortescue's symmetrical components
    and is critical to the N-Phase system's decomposition.

    Mathematical justification:
      1 + a + a^2 = (a^3 - 1) / (a - 1) * (a - 1) / (a - 1)
      Since a^3 = 1, the numerator of the geometric sum is 0.
      (Requires a != 1, which holds since a = exp(2*pi*I/3) != 1.) -/
theorem cube_roots_sum_zero (ha : alpha ≠ 1) :
    1 + alpha + alpha ^ 2 = 0 := by
  -- From a^3 = 1 and a^3 - 1 = (a - 1)(1 + a + a^2), since a != 1.
  have h3 : alpha ^ 3 = 1 := alpha_cubed
  have h_factor : alpha ^ 3 - 1 = (alpha - 1) * (1 + alpha + alpha ^ 2) := by ring
  have h_zero : alpha ^ 3 - 1 = 0 := sub_eq_zero.mpr h3
  rw [h_zero] at h_factor
  have h_ne : alpha - 1 ≠ 0 := sub_ne_zero.mpr ha
  have h_prod_zero : (alpha - 1) * (1 + alpha + alpha ^ 2) = 0 := h_factor.symm
  exact (mul_eq_zero.mp h_prod_zero).resolve_left h_ne

-- ============================================================================
-- Section 5: 4-Phase Specialization (Versor Operators)
-- ============================================================================
-- The 4-phase system connects to Dollard's versor operators {1, j, h, k}.
-- We showed in basic_operators.lean that these are {1, I, -1, -I},
-- i.e., the 4th roots of unity. Here we derive this from the polyphase formula.

/-- The primitive 4th root of unity. -/
noncomputable def omega4 : ℂ := omega 4

/-- omega4 is exp(2*pi*I/4) = exp(pi*I/2). -/
theorem omega4_def : omega4 = Complex.exp (2 * Real.pi * Complex.I / 4) := by
  simp [omega4, omega]

/-- omega4^4 = 1: The 4th root of unity raised to the 4th power equals 1. -/
theorem omega4_fourth : omega4 ^ 4 = 1 := by
  have hN : (4 : ℂ) ≠ 0 := by norm_num
  exact omega_pow_N 4 hN

/-- omega4 = I (the imaginary unit).
    exp(2*pi*I/4) = exp(pi*I/2) = cos(pi/2) + I*sin(pi/2) = 0 + I*1 = I.

    This connects the polyphase formula to Dollard's j operator. -/
theorem omega4_eq_I : omega4 = Complex.I := by
  simp only [omega4, omega]
  -- exp(2*pi*I/4) = exp((pi/2)*I) = cos(pi/2) + I*sin(pi/2) = 0 + I*1 = I
  suffices h : Complex.exp (↑(Real.pi / 2) * Complex.I) = Complex.I by
    convert h using 2; push_cast; ring
  apply Complex.ext <;> simp

/-- The four 4th roots of unity are {1, I, -1, -I}.
    These are exactly Dollard's versor operators {1, j, h, k}. -/
theorem four_phase_roots :
    omega4 ^ 0 = 1 ∧
    omega4 ^ 1 = Complex.I ∧
    omega4 ^ 2 = -1 ∧
    omega4 ^ 3 = -Complex.I := by
  refine ⟨by ring, ?_, ?_, ?_⟩
  · -- omega4^1 = I
    simp [omega4_eq_I]
  · -- omega4^2 = -1
    have h1 : omega4 = Complex.I := omega4_eq_I
    rw [h1]
    exact Complex.I_sq
  · -- omega4^3 = -I
    have h1 : omega4 = Complex.I := omega4_eq_I
    rw [h1]
    have : Complex.I ^ 3 = Complex.I ^ 2 * Complex.I := by ring
    rw [this, Complex.I_sq]
    ring

/-- Connection to Dollard's versor notation:
    1 = omega4^0  (identity)
    j = omega4^1  (90-degree rotation = I)
    h = omega4^2  (180-degree rotation = -1)
    k = omega4^3  (270-degree rotation = -I = -j)

    This confirms the finding from basic_operators.lean:
    the versor algebra is exactly the cyclic group Z_4 = the 4th roots of unity. -/
theorem versor_is_fourth_roots :
    omega4 ^ 0 = 1 ∧
    omega4 ^ 1 = Complex.I ∧         -- j = I
    omega4 ^ 2 = -(1 : ℂ) ∧          -- h = -1
    omega4 ^ 3 = -Complex.I := by     -- k = -I = -j
  exact four_phase_roots

-- ============================================================================
-- Section 6: General Properties of Nth Roots of Unity
-- ============================================================================

/-- Periodicity: omega(N)^(N+k) = omega(N)^k.
    Roots of unity are periodic with period N. -/
theorem omega_periodic (N k : ℕ) (hN : (N : ℂ) ≠ 0) :
    omega N ^ (N + k) = omega N ^ k := by
  rw [pow_add]
  rw [omega_pow_N N hN]
  ring

/-- Product of roots: nthRootUnity(a, N) * nthRootUnity(b, N) = nthRootUnity(a+b, N).
    Roots of unity multiply by adding exponents (they form a group under multiplication). -/
theorem nthRoot_mul (a b N : ℕ) (hN : (N : ℂ) ≠ 0) :
    nthRootUnity a N * nthRootUnity b N = nthRootUnity (a + b) N := by
  simp only [nthRootUnity]
  rw [← Complex.exp_add]
  congr 1
  push_cast
  field_simp

/-- The Nth roots of unity lie on the unit circle: |omega(N)| = 1.
    Every root of unity has absolute value 1.
    Requires showing Re(2*pi*I/N) = 0 (purely imaginary exponent). -/
theorem omega_on_unit_circle (N : ℕ) (hN : N ≠ 0) : ‖omega N‖ = 1 := by
  simp only [omega]
  -- Rewrite exponent as (real)*I, then use |exp(r*I)| = 1.
  have h : (2 : ℂ) * ↑Real.pi * Complex.I / (↑N : ℂ) =
    ↑(2 * Real.pi / (↑N : ℝ)) * Complex.I := by
    push_cast
    have : (↑N : ℂ) ≠ 0 := Nat.cast_ne_zero.mpr hN
    field_simp
  rw [h]
  exact Complex.norm_exp_ofReal_mul_I _

