private def scale_table : Array (List (Nat × Int)) :=
  let base := (List.replicate 10000 ([] : List (Nat × Int))).toArray
  let t := scale_brackets.foldl (fun acc (i, j, terms) =>
    acc.set! (i * 100 + j) terms) base
  scale_brackets.foldl (fun acc (i, j, terms) =>
    acc.set! (j * 100 + i) (terms.map fun (k, c) => (k, -c))) t

private def s_bkt (i j : Nat) : List (Nat × Int) :=
  scale_table.getD (i * 100 + j) []

private def s_jterm (bkt : List (Nat × Int)) (k l : Nat) : Int :=
  bkt.foldl (fun acc (m, c_m) =>
    let f_mkl := (s_bkt m k).foldl
      (fun a (idx, c) => if idx == l then a + c else a) 0
    acc + c_m * f_mkl) 0

def s_jacobi (i j k l : Fin 100) : Int :=
  s_jterm (s_bkt i.val j.val) k.val l.val +
  s_jterm (s_bkt j.val k.val) i.val l.val +
  s_jterm (s_bkt k.val i.val) j.val l.val

/-- Sparse Jacobi for so(10) in Fin 100. 100,000,000 evaluations. -/
theorem scale_sparse_jacobi : ∀ (i j k l : Fin 100),
    s_jacobi i j k l = 0 := by
  native_decide
