/-
UFT Formal Verification - SU(5)C →ₗ⁅ℝ⁆ SO(10) Lie Homomorphism
=================================================================

CERTIFIED LIE ALGEBRA EMBEDDING: COMPACT su(5) INTO so(10)

This file constructs a LieHom from the compact-form su(5)
(defined in su5c_compact.lean) to so(10) (defined in so10_grand.lean).

The embedding maps each SU5C generator to its SO(10) representation:
  H_a → L_{a,a+5} - L_{a+1,a+6}     (Cartan generators)
  R_{ab} → L_{ab} + L_{a+5,b+5}       (real rotation generators)
  S_{ab} → L_{a,b+5} + L_{b,a+5}      (symplectic generators)

The key theorem: su5c_embed preserves the Lie bracket:
  embed([X,Y]_{su5c}) = [embed(X), embed(Y)]_{so10}

This gives a standalone type with morphism composition capability,
required for Papers 3 & 4 (breaking chains and generation counting).

References:
  - su5c_compact.lean: SU5C type with LieAlgebra ℝ instance
  - so10_grand.lean: SO10 type with LieAlgebra ℝ instance
  - su5_so10_embedding.lean: generator definitions (source of embedding map)
  - scripts/su5c_bracket_gen.py: embedding function verification
-/

import clifford.su5c_compact
import clifford.so10_grand

/-! ## Part 1: The Embedding Function -/

/-- The embedding of compact su(5) into so(10).
    Each SU5C component maps linearly to SO10 components.
    Generated by scripts/su5c_bracket_gen.py.

    24 of the 45 SO10 slots receive SU5C data.
    21 slots are zero (the coset directions so(10)/u(5)). -/
def su5c_toSO10 (x : SU5C) : SO10 where
  l12 := x.r12
  l13 := x.r13
  l14 := x.r14
  l15 := x.r15
  l16 := x.h1
  l17 := x.s12
  l18 := x.s13
  l19 := x.s14
  l1a := x.s15
  l23 := x.r23
  l24 := x.r24
  l25 := x.r25
  l26 := x.s12
  l27 := -x.h1 + x.h2
  l28 := x.s23
  l29 := x.s24
  l2a := x.s25
  l34 := x.r34
  l35 := x.r35
  l36 := x.s13
  l37 := x.s23
  l38 := -x.h2 + x.h3
  l39 := x.s34
  l3a := x.s35
  l45 := x.r45
  l46 := x.s14
  l47 := x.s24
  l48 := x.s34
  l49 := -x.h3 + x.h4
  l4a := x.s45
  l56 := x.s15
  l57 := x.s25
  l58 := x.s35
  l59 := x.s45
  l5a := -x.h4
  l67 := x.r12
  l68 := x.r13
  l69 := x.r14
  l6a := x.r15
  l78 := x.r23
  l79 := x.r24
  l7a := x.r25
  l89 := x.r34
  l8a := x.r35
  l9a := x.r45

/-! ## Part 2: Linearity Proofs -/

theorem su5c_toSO10_add (a b : SU5C) :
    su5c_toSO10 (a + b) = su5c_toSO10 a + su5c_toSO10 b := by
  ext <;> simp [su5c_toSO10, SU5C.add, SO10.add, SU5C.add_def, SO10.add_def] <;> ring

theorem su5c_toSO10_smul (r : ℝ) (a : SU5C) :
    su5c_toSO10 (r • a) = r • su5c_toSO10 a := by
  ext <;> simp [su5c_toSO10, SU5C.smul, SO10.smul, SU5C.smul_def', SO10.smul_def'] <;> ring

/-! ## Part 3: Bracket Preservation (The Main Theorem) -/

set_option maxHeartbeats 32000000 in
/-- THE HOMOMORPHISM THEOREM: the embedding preserves the Lie bracket.
    su5c_toSO10([X,Y]_{su5c}) = [su5c_toSO10(X), su5c_toSO10(Y)]_{so10}

    This certifies that su(5) is a genuine Lie subalgebra of so(10),
    not just "generators that commute with J" but "algebraically identical
    bracket structure under the embedding map."

    48 input variables (24 per argument) × 45 output goals × polynomial ring.
    Budget: 32M heartbeats. -/
theorem su5c_toSO10_lie (x y : SU5C) :
    su5c_toSO10 ⁅x, y⁆ = ⁅su5c_toSO10 x, su5c_toSO10 y⁆ := by
  ext <;> simp [su5c_toSO10, SU5C.comm, SO10.comm, SU5C.bracket_def', SO10.bracket_def'] <;> ring

/-! ## Part 4: The Certified LieHom -/

/-- The certified Lie algebra homomorphism SU5C →ₗ⁅ℝ⁆ SO10.
    This is the standalone morphism needed for:
    - Morphism composition in breaking chains (Paper 3)
    - Representation pullback for generation counting (Paper 4) -/
def su5c_embed : SU5C →ₗ⁅ℝ⁆ SO10 :=
  { toLinearMap := {
      toFun := su5c_toSO10
      map_add' := su5c_toSO10_add
      map_smul' := su5c_toSO10_smul
    }
    map_lie' := fun {x} {y} => su5c_toSO10_lie x y }

/-! ## Summary

### What this file proves:
1. Linear embedding su5c_toSO10 : SU5C → SO10 (Part 1)
2. Linearity: preserves addition and scalar multiplication (Part 2)
3. Bracket preservation: embed([X,Y]) = [embed(X), embed(Y)] (Part 3)
4. Certified LieHom: SU5C →ₗ⁅ℝ⁆ SO10 (Part 4)

### What this enables:
- **Morphism composition**: compose with SU3 →ₗ⁅ℝ⁆ SU5C for the full
  breaking chain SU(3)×SU(2)×U(1) ↪ SU(5) ↪ SO(10)
- **Representation pullback**: pull SO(10) spinor representations back
  to SU(5) for generation counting (16 = 1 + 5̄ + 10)
- **Connects Options A and B**: this standalone morphism (Option B)
  maps the same generators as the subalgebra inclusion (Option A)

### Relationship to Option A (su5_subalgebra.lean):
Option A defines u(5) as a LieSubalgebra of SO10 and gets the
